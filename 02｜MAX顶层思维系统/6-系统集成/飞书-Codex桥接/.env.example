# 复制为 .env 后填写。不要把 .env 发给别人。
# 飞书开放平台：自建应用 -> 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 中国大陆飞书默认使用 open.feishu.cn；Lark 国际版可改为 https://open.larksuite.com
FEISHU_BASE_URL=https://open.feishu.cn

# 可选：用于 send-text / push-md-as-message 的默认接收人
# receive_id_type 常用：open_id / user_id / union_id / email / chat_id
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_RECEIVE_ID=

# 可选：用于 docx-create 的默认云文档文件夹 token
FEISHU_DEFAULT_FOLDER_TOKEN=
